  file_change {
    absolute_path_uri: "file:///src/components/Functions.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { Sigma, Code, Play, HelpCircle, Terminal } from \'lucide-react\';\n\ninterface RuleFx {\n  name: string;\n  signature: string;\n  description: string;\n  parameters: { name: string; type: string; description: string }[];\n  sampleOutput: string;\n}\n\nexport default function Functions() {\n  const [activeFx, setActiveFx] = useState<string>(\'vel(24h)\');\n  const [testParamInput, setTestParamInput] = useState<string>(\'usr_abc992\');\n  const [executionOutput, setExecutionOutput] = useState<string>(\'\');\n\n  const functionsList: RuleFx[] = [\n    {\n      name: \'vel(24h)\',\n      signature: \'vel(userId: str, windowHours: int) -> int\',\n      description: \'Calculates the transaction frequency of a specific user within the declared rolling hour window.\',\n      parameters: [\n        { name: \'userId\', type: \'str\', description: \'The identifier of the transacting client.\' },\n        { name: \'windowHours\', type: \'int\', description: \'Size of the rolling evaluation window (defaults to 24).\' },\n      ],\n      sampleOutput: \'5\',\n    },\n    {\n      name: \'avgSpend(30d)\',\n      signature: \'avgSpend(userId: str, windowDays: int) -> num\',\n      description: \'Finds the historical daily mean spend volume of the selected user context.\',\n      parameters: [\n        { name: \'userId\', type: \'str\', description: \'Unique identifier of the client.\' },\n        { name: \'windowDays\', type: \'int\', description: \'Rolling history day span (defaults to 30).\' },\n      ],\n      sampleOutput: \'4500.50\',\n    },\n    {\n      name: \'isMatchGeo()\',\n      signature: \'isMatchGeo(ip: str, knownHotspots: str[]) -> bool\',\n      description: \'Tries to map geographic subnets to confirm whether access coordinates are validated client access zones.\',\n      parameters: [\n        { name: \'ip\', type: \'str\', description: \'Transaction remote ip protocol address.\' },\n        { name: \'knownHotspots\', type: \'str[]\', description: \'A collection of countries previously declared secure.\' },\n      ],\n      sampleOutput: \'true\',\n    },\n  ];\n\n  const selectedFx = functionsList.find((f) => f.name.startsWith(activeFx.slice(0, 3)));\n\n  const handleTestRun = () => {\n    if (!selectedFx) return;\n    setExecutionOutput(\n      `[COMPILER] Invoking evaluation: ${selectedFx.name} for parameters [${testParamInput}]\\n[SUCCESS] Return output value: \"${selectedFx.sampleOutput}\"`\n    );\n  };\n\n  return (\n    <div className=\"flex-grow flex overflow-hidden bg-background max-h-[calc(100vh-56px)]\">\n      {/* Left List of functions */}\n      <aside className=\"w-80 border-r border-outline-variant bg-surface-container-low flex flex-col shrink-0\">\n        <div className=\"p-4 border-b border-outline-variant\">\n          <h3 className=\"text-xs font-bold text-on-surface-variant uppercase tracking-wider\">Functions Directory</h3>\n          <p className=\"text-[11px] text-on-surface-variant leading-normal mt-1\">\n            Programmatic logic filters accessible by rules formula.\n          </p>\n        </div>\n\n        <nav className=\"flex-grow overflow-y-auto p-2 space-y-1\">\n          {functionsList.map((fx) => (\n            <button\n              key={fx.name}\n              onClick={() => {\n                setActiveFx(fx.name);\n                setExecutionOutput(\'\');\n              }}\n              className={`w-full text-left px-3 py-2.5 rounded transition-all cursor-pointer flex items-center gap-2.5 ${\n                fx.name === activeFx\n                  ? \'bg-primary text-white font-bold\'\n                  : \'text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high\'\n              }`}\n            >\n              <Sigma className=\"w-4 h-4 shrink-0\" />\n              <div className=\"min-w-0\">\n                <div className=\"text-xs truncate\">{fx.name}</div>\n                <div className={`text-[10px] truncate ${fx.name === activeFx ? \'text-white/80\' : \'text-on-surface-variant\'}`}>\n                  {fx.signature}\n                </div>\n              </div>\n            </button>\n          ))}\n        </nav>\n      </aside>\n\n      {/* Main Details and Tester area */}\n      <main className=\"flex-1 p-6 overflow-y-auto custom-scrollbar flex flex-col gap-6\">\n        {selectedFx ? (\n          <>\n            {/* Function overview */}\n            <div className=\"bg-white border border-outline-variant rounded-lg p-5 shadow-sm\">\n              <div className=\"flex items-center gap-2 mb-2\">\n                <Code className=\"w-5 h-5 text-primary\" />\n                <h2 className=\"text-sm font-bold text-on-surface\">{selectedFx.name} Signature</h2>\n              </div>\n              <pre className=\"bg-surface-container p-3 rounded font-mono text-xs text-primary font-bold border border-outline-variant select-all\">\n                {selectedFx.signature}\n              </pre>\n              <p className=\"text-xs text-on-surface-variant mt-3 leading-relaxed\">\n                {selectedFx.description}\n              </p>\n            </div>\n\n            {/* Parameters list */}\n            <div className=\"bg-white border border-outline-variant rounded-lg p-5 shadow-sm\">\n              <h3 className=\"text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-3\">\n                Parameters Configuration\n              </h3>\n              <div className=\"divide-y divide-outline-variant\">\n                {selectedFx.parameters.map((param) => (\n                  <div key={param.name} className=\"py-2.5 flex items-start gap-4\">\n                    <span className=\"font-mono text-xs font-bold text-secondary bg-surface-container px-1.5 py-0.5 rounded border border-outline-variant min-w-[80px] text-center\">\n                      {param.name}\n                    </span>\n                    <span className=\"font-mono text-[10px] bg-outline-variant bg-opacity-20 px-1 py-0.5 rounded text-on-surface-variant font-extrabold uppercase\">\n                      {param.type}\n                    </span>\n                    <span className=\"text-xs text-on-surface-variant leading-normal\">\n                      {param.description}\n                    </span>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Interactive functional test executor */}\n            <div className=\"bg-white border border-outline-variant rounded-lg p-5 shadow-sm mt-auto\">\n              <h3 className=\"text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-3\">\n                Run Function Evaluation Test\n              </h3>\n\n              <div className=\"flex items-center gap-3 mb-4\">\n                <div className=\"flex-1\">\n                  <label className=\"block text-[10px] font-bold text-on-surface-variant mb-1 uppercase tracking-wider\">\n                    Test Parameter Input (userId / ip)\n                  </label>\n                  <input\n                    type=\"text\"\n                    value={testParamInput}\n                    onChange={(e) => setTestParamInput(e.target.value)}\n                    className=\"w-full h-8 px-3 text-xs border border-outline-variant rounded bg-white text-on-background focus:border-secondary outline-none font-mono\"\n                  />\n                </div>\n\n                <button\n                  onClick={handleTestRun}\n                  className=\"h-8 px-4 bg-primary hover:bg-primary-hover text-white font-bold text-xs rounded transition-all cursor-pointer shadow-sm flex items-center gap-1.5 self-end\"\n                >\n                  <Play className=\"w-3.5 h-3.5 fill-white text-white\" />\n                  <span>Execute Evaluation</span>\n                </button>\n              </div>\n\n              {/* Console log outputs */}\n              {executionOutput && (\n                <div className=\"bg-black text-emerald-400 font-mono text-xs rounded p-4 border border-outline-variant shadow-inner select-all\">\n                  <div className=\"text-gray-500 mb-1 flex items-center gap-1\">\n                    <Terminal className=\"w-3.5 h-3.5\" />\n                    <span>Evaluation Result Stream</span>\n                  </div>\n                  <pre className=\"leading-relaxed whitespace-pre-wrap\">{executionOutput}</pre>\n                </div>\n              )}\n            </div>\n          </>\n        ) : null}\n      </main>\n    </div>\n  );\n}\n"
    }
